                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01 Auth",
      "item": [
        {
          "name": "Register Normal User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now();",
                  "pm.collectionVariables.set(\"newUsername\", `student${suffix}`);",
                  "pm.collectionVariables.set(\"newEmail\", `student${suffix}@example.com`);",
                  "pm.collectionVariables.set(\"newPassword\", \"password123\");"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"register returns 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test(\"register response is successful\", function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.data.email).to.eql(pm.collectionVariables.get(\"newEmail\"));",
                  "});",
                  "",
                  "pm.collectionVariables.set(\"registeredUserId\", String(json.data.id));",
                  "pm.collectionVariables.set(\"targetUserId\", String(json.data.id));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{newUsername}}\",\n  \"email\": \"{{newEmail}}\",\n  \"password\": \"{{newPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login Bootstrap Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"login returns 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test(\"login returns token\", function () {",
                  "  pm.expect(json.data.accessToken).to.be.a(\"string\").and.not.empty;",
                  "  pm.expect(json.data.tokenType).to.eql(\"Bearer\");",
                  "});",
                  "",
                  "pm.environment.set(\"token\", json.data.accessToken);",
                  "pm.collectionVariables.set(\"token\", json.data.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "me"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"current user returns 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"current user is admin\", function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.role).to.eql(\"ADMIN\");",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 Admin Users",
      "auth": {
        "type": "bearer",
