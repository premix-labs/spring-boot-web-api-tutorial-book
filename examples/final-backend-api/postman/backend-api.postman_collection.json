                "status"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"change status returns 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
