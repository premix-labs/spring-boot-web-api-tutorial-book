---
// 404.astro — Branded not-found page, styled with the shared design system.
import '@fontsource/inter/latin.css';
import '@fontsource/space-grotesk/700.css';
import '../styles/global.css';
import { siteConfig } from '../site.config';
import { getCollection } from 'astro:content';
import { withBase } from '../utils/url';
import { Home, ArrowRight } from '@lucide/astro';

const allChapters = await getCollection('chapters', ({ data }) => !data.draft);
const firstChapter = allChapters.sort((a, b) => a.data.chapter - b.data.chapter)[0];
const startHref = withBase(firstChapter ? firstChapter.id : '');
---

<!doctype html>
<html lang={siteConfig.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>Page not found — {siteConfig.title}</title>

    <script is:inline define:vars={{ defaultTheme: siteConfig.defaultTheme }}>
      document.documentElement.setAttribute('data-theme', localStorage.getItem('site-theme') || defaultTheme);
    </script>

    <link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
  </head>
  <body>
    <div class="bg-grid fixed inset-0 w-full h-full -z-10 pointer-events-none opacity-10"></div>
    <main class="min-h-screen flex flex-col items-center justify-center text-center px-8">
      <div
        class="font-display text-[7rem] lg:text-[10rem] font-extrabold leading-none bg-gradient-to-br from-indigo-500 via-purple-500 to-pink-500 text-transparent bg-clip-text"
      >
        404
      </div>
      <h1 class="text-2xl lg:text-3xl font-bold text-content-main mt-4 mb-3">This page went missing</h1>
      <p class="text-content-mut max-w-[440px] mb-8">
        The page you're looking for doesn't exist or may have moved. Let's get you back on track.
      </p>
      <div class="flex gap-4 flex-wrap justify-center">
        <a
          href={withBase('')}
          class="inline-flex items-center gap-2 py-3 px-6 bg-gradient-to-br from-indigo-500 to-purple-600 text-white font-bold rounded-lg no-underline transition-all duration-200 hover:-translate-y-0.5 shadow-[0_4px_16px_rgba(99,102,241,0.4)]"
        >
          <Home class="w-4 h-4" />
          <span>Back to Home</span>
        </a>
        <a
          href={startHref}
          class="inline-flex items-center gap-2 py-3 px-6 bg-surface-elev border border-line-def text-content-sec font-semibold rounded-lg no-underline transition-all duration-200 hover:bg-surface-hover hover:text-content-main hover:-translate-y-0.5"
        >
          <span>Start Reading</span>
          <ArrowRight class="w-4 h-4" />
        </a>
      </div>
    </main>
  </body>
</html>
